<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_habit_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:paddingHorizontal="10dp"
    android:background="@drawable/widget_item_normal_bg">

    <ImageView
        android:id="@+id/widget_habit_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="8dp"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/widget_habit_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Habit Name"
        android:textColor="#E4E3EC"
        android:textSize="14sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:singleLine="true" />

    <TextView
        android:id="@+id/widget_habit_minus"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="-"
        android:textColor="#E4E3EC"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/widget_item_normal_bg"
        android:layout_marginEnd="6dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_habit_plus"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="+"
        android:textColor="#E4E3EC"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/widget_item_normal_bg"
        android:layout_marginEnd="6dp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/widget_habit_check"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_widget_circle_unchecked"
        android:contentDescription="Check Habit" />
</LinearLayout>
